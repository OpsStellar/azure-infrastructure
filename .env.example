# Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# Azure Service Principal
ARM_CLIENT_ID=your-client-id-here
ARM_CLIENT_SECRET=your-client-secret-here
ARM_TENANT_ID=your-tenant-id-here
ARM_SUBSCRIPTION_ID=your-subscription-id-here

# Azure Storage for Pulumi State
AZURE_STORAGE_ACCOUNT=pulumistate3033355
AZURE_STORAGE_KEY=your-storage-key-here

# Pulumi Config Passphrase
PULUMI_CONFIG_PASSPHRASE=your-passphrase-here
